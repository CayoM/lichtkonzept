---
const base = import.meta.env.BASE_URL;
---

<section class="lk-hero" aria-labelledby="hero-headline">
  <div class="lk-hero-image" aria-hidden="true">
    <img
      src={`${base}images/projects/easyfitness-bornheim.jpg`}
      alt=""
      loading="eager"
      fetchpriority="high"
    />
    <div class="lk-hero-grad"></div>
  </div>

  <div class="lk-hero-content">
    <p class="lk-eyebrow" data-reveal>Lichtdesign · Eigene Kollektion · Umsetzung</p>
    <h1 id="hero-headline" class="lk-display" data-reveal style="--reveal-delay: 120ms;">
      Licht ist nicht<br />
      <span class="lk-display-italic">Beleuchtung.</span>
    </h1>
    <p class="lk-hero-sub" data-reveal style="--reveal-delay: 280ms;">
      Wir entwerfen, fertigen und installieren Lichtkonzepte für Räume,
      die mehr sein wollen als hell.
    </p>

    <div class="lk-hero-actions" data-reveal style="--reveal-delay: 440ms;">
      <a href="#kontakt" class="lk-cta">
        Lichtgespräch buchen
        <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
          <path d="M1 7H13M13 7L8 2M13 7L8 12" stroke="currentColor" stroke-width="1.4" stroke-linecap="square"/>
        </svg>
      </a>
      <a href="#methodik" class="lk-link-quiet lk-hero-secondary">So denken wir Licht</a>
    </div>
  </div>

  <div class="lk-hero-scroll-hint" aria-hidden="true">
    <span class="lk-label">Scrollen</span>
    <span class="lk-hero-line"></span>
  </div>
</section>

<style>
  .lk-hero {
    position: relative;
    min-height: 100dvh;
    padding-inline: var(--gutter);
    padding-top: 30vh;
    padding-bottom: 8rem;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    overflow: hidden;
    isolation: isolate;
  }

  .lk-hero-image {
    position: absolute;
    inset: 0;
    z-index: -1;
  }

  .lk-hero-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    /* Push die obere "FINISHED PROJECT" Stempel raus, sichtbar bleibt der Korridor mit den Lichtern */
    object-position: center 78%;
  }

  .lk-hero-grad {
    position: absolute;
    inset: 0;
    background:
      linear-gradient(
        180deg,
        color-mix(in oklch, var(--color-lk-bg) 80%, transparent) 0%,
        color-mix(in oklch, var(--color-lk-bg) 30%, transparent) 30%,
        transparent 50%,
        color-mix(in oklch, var(--color-lk-bg) 70%, transparent) 80%,
        var(--color-lk-bg) 100%
      ),
      linear-gradient(
        90deg,
        color-mix(in oklch, var(--color-lk-bg) 70%, transparent) 0%,
        transparent 50%
      );
  }

  .lk-hero-content {
    max-width: 1440px;
    width: 100%;
    margin-inline: auto;
    position: relative;
  }

  .lk-hero-sub {
    font-family: var(--font-display);
    font-style: italic;
    font-size: clamp(1.25rem, 1.8vw, 1.625rem);
    color: var(--color-lk-fg-muted);
    margin-top: clamp(1.5rem, 3vw, 2.25rem);
    max-width: 36ch;
    line-height: 1.4;
  }

  .lk-hero-actions {
    margin-top: clamp(2rem, 4vw, 3rem);
    display: flex;
    align-items: center;
    gap: clamp(1rem, 2.5vw, 2rem);
    flex-wrap: wrap;
  }

  .lk-hero-secondary {
    font-size: 0.875rem;
    letter-spacing: 0.02em;
  }

  .lk-hero-scroll-hint {
    position: absolute;
    bottom: 2.5rem;
    right: var(--gutter);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.75rem;
    color: var(--color-lk-fg-quiet);
  }

  .lk-hero-line {
    width: 1px;
    height: 56px;
    background: linear-gradient(180deg, currentColor, transparent);
    animation: lk-scroll-drop 2.4s var(--ease-fluid) infinite;
  }

  @keyframes lk-scroll-drop {
    0% {
      transform-origin: top;
      transform: scaleY(0);
    }
    50% {
      transform-origin: top;
      transform: scaleY(1);
    }
    51% {
      transform-origin: bottom;
      transform: scaleY(1);
    }
    100% {
      transform-origin: bottom;
      transform: scaleY(0);
    }
  }

  @media (max-width: 720px) {
    .lk-hero-scroll-hint {
      display: none;
    }
  }

  @media (prefers-reduced-motion: no-preference) {
    .lk-hero-image {
      transform: translateY(var(--hero-parallax, 0));
      transition: transform 60ms linear;
    }
  }
</style>

<script>
  const img = document.querySelector<HTMLElement>('.lk-hero-image');
  if (img && window.matchMedia('(prefers-reduced-motion: no-preference)').matches) {
    let ticking = false;
    const onScroll = () => {
      if (ticking) return;
      ticking = true;
      requestAnimationFrame(() => {
        const y = Math.min(window.scrollY * 0.35, 240);
        img.style.setProperty('--hero-parallax', `${y}px`);
        ticking = false;
      });
    };
    window.addEventListener('scroll', onScroll, { passive: true });
  }
</script>
