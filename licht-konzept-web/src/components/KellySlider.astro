---
const base = import.meta.env.BASE_URL;

const steps = [
  {
    name: 'Grundlicht',
    subtitle: 'Licht zum Sehen',
    body: 'Orientierung. Das Auge findet seinen Weg. Eine weiche, gleichmäßige Lichtbasis macht den Raum bewohnbar.',
    image: 'kelly-1-grund.svg',
  },
  {
    name: 'Akzentlicht',
    subtitle: 'Licht zum Hinsehen',
    body: 'Aufmerksamkeit. Das Auge wird geführt. Gezielte Strahler heben Architektur, Kunst und Objekte hervor.',
    image: 'kelly-2-akzent.svg',
  },
  {
    name: 'Schmucklicht',
    subtitle: 'Licht zum Ansehen',
    body: 'Emotion. Das Auge bleibt hängen. Dekorative Leuchten werden selbst zur Skulptur — Licht als Schmuck.',
    image: 'kelly-3-schmuck.svg',
  },
];
---

<section class="lk-section lk-kelly" id="methodik" aria-labelledby="kelly-title">
  <div class="lk-container">
    <header class="lk-kelly-header" data-reveal>
      <p class="lk-eyebrow">Methodik · Richard Kelly</p>
      <h2 id="kelly-title" class="lk-h1">
        So verstehen wir <span class="lk-display-italic">Licht.</span>
      </h2>
      <p class="lk-body lk-kelly-intro">
        Drei Schichten, die jeder Raum braucht. Bewege den Greifer im Frame nach links und
        rechts, um zu sehen, wie sich derselbe Raum durch jede Schicht verändert.
      </p>
    </header>

    <div class="lk-kelly-stage" data-kelly-root data-reveal style="--reveal-delay: 160ms;">
      <div class="lk-kelly-frame" data-kelly-frame style="--kelly-pos: 0;">
        <img class="lk-kelly-base" src={`${base}images/placeholders/kelly-base.svg`} alt="" aria-hidden="true" />
        {steps.map((step, i) => (
          <img
            data-kelly-layer={i}
            class="lk-kelly-layer"
            src={`${base}images/placeholders/${step.image}`}
            alt={i === 0 ? 'Aktuell aktive Lichtschicht im Raum' : ''}
            aria-hidden={i !== 0}
          />
        ))}
        <div class="lk-kelly-vignette" aria-hidden="true"></div>

        {/* Beschreibung oben rechts im Frame */}
        <div class="lk-kelly-info" aria-live="polite">
          {steps.map((step, i) => (
            <div data-kelly-label={i} data-kelly-name={step.name} class="lk-kelly-info-card">
              <div class="lk-kelly-info-meta">
                <span class="lk-label">Schicht {String(i + 1).padStart(2, '0')}</span>
                <span class="lk-kelly-info-sub lk-display-italic">{step.subtitle}</span>
              </div>
              <h3 class="lk-kelly-info-title">{step.name}</h3>
              <p class="lk-kelly-info-body">{step.body}</p>
            </div>
          ))}
        </div>

        {/* Drag-Handle on top of image */}
        <div
          class="lk-kelly-handle"
          data-kelly-handle
          role="slider"
          tabindex="0"
          aria-label="Lichtschicht auswählen — ziehen oder Pfeiltasten verwenden"
          aria-valuemin="0"
          aria-valuemax="2"
          aria-valuenow="0"
          aria-valuetext="Grundlicht"
        >
          <div class="lk-kelly-handle-line" aria-hidden="true"></div>
          <div class="lk-kelly-handle-grip" aria-hidden="true">
            <svg width="16" height="16" viewBox="0 0 16 16" fill="none">
              <path d="M6 4L3 8L6 12" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/>
              <path d="M10 4L13 8L10 12" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </div>
        </div>

        {/* Drag-Hinweis — fadet nach erster Interaktion */}
        <div class="lk-kelly-hint" data-kelly-hint aria-hidden="true">
          <span class="lk-kelly-hint-arrow lk-kelly-hint-arrow--l">‹</span>
          <span class="lk-kelly-hint-text">ziehen</span>
          <span class="lk-kelly-hint-arrow lk-kelly-hint-arrow--r">›</span>
        </div>

        {/* Quote unten zentriert im Frame */}
        <figure class="lk-kelly-quote-inset">
          <blockquote>
            <p class="lk-display-italic lk-kelly-quote-text">„Variety is the spice of light."</p>
          </blockquote>
          <figcaption class="lk-label">— Richard Kelly, Lichtarchitekt (1910–1977)</figcaption>
        </figure>

        {/* Position-Stops am Frame-Boden */}
        <div class="lk-kelly-stops" aria-hidden="true">
          {steps.map((step, i) => (
            <button
              type="button"
              data-kelly-stop={i}
              class="lk-kelly-stop"
              aria-label={`Schicht ${i + 1}: ${step.name}`}
              style={`--stop-pos: ${(i / 2) * 100}%`}
            >
              <span class="lk-kelly-stop-num">{String(i + 1).padStart(2, '0')}</span>
            </button>
          ))}
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  import '@lib/kelly-slider';
</script>

<style>
  .lk-kelly {
    background: linear-gradient(180deg, var(--color-lk-bg) 0%, var(--color-lk-bg-elev) 50%, var(--color-lk-bg) 100%);
    position: relative;
    overflow: hidden;
  }

  .lk-kelly-header {
    max-width: 720px;
  }

  .lk-kelly-intro {
    margin-top: 1.25rem;
  }

  .lk-kelly-stage {
    /* Eng an den Header — keine grosse Lücke */
    margin-top: 2rem;
  }

  /* === Frame === */
  .lk-kelly-frame {
    position: relative;
    aspect-ratio: 16 / 9;
    border-radius: 4px;
    overflow: hidden;
    border: 1px solid var(--color-lk-line);
    background: var(--color-lk-bg-elev);
    cursor: pointer;
    user-select: none;
    -webkit-user-select: none;
  }

  .lk-kelly-base,
  .lk-kelly-layer {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    pointer-events: none;
  }

  .lk-kelly-layer {
    opacity: 0;
    transition: opacity 240ms var(--ease-cinema);
    will-change: opacity;
  }

  .lk-kelly-vignette {
    position: absolute;
    inset: 0;
    pointer-events: none;
    background:
      radial-gradient(ellipse at center, transparent 50%, color-mix(in oklch, var(--color-lk-bg) 55%, transparent) 100%),
      /* Subtile vignette oben rechts für besseren Info-Kontrast */
      linear-gradient(225deg, color-mix(in oklch, var(--color-lk-bg) 50%, transparent), transparent 35%);
  }

  /* === Info-Card oben rechts === */
  .lk-kelly-info {
    position: absolute;
    top: clamp(1.25rem, 2.5vw, 2rem);
    right: clamp(1.25rem, 2.5vw, 2rem);
    width: clamp(220px, 30%, 340px);
    z-index: 2;
    pointer-events: none;
  }

  .lk-kelly-info-card {
    position: absolute;
    inset: 0;
    opacity: 0;
    transform: translateY(8px);
    transition:
      opacity 360ms var(--ease-cinema),
      transform 360ms var(--ease-cinema);
    text-align: right;
  }

  .lk-kelly-info-card[data-active='true'] {
    opacity: 1;
    transform: none;
  }

  .lk-kelly-info-meta {
    display: inline-flex;
    align-items: baseline;
    gap: 0.75rem;
    padding-bottom: 0.5rem;
    border-bottom: 1px solid color-mix(in oklch, var(--color-lk-fg) 22%, transparent);
    margin-bottom: 0.75rem;
  }

  .lk-kelly-info-meta .lk-label {
    color: color-mix(in oklch, var(--color-lk-fg) 65%, transparent);
  }

  .lk-kelly-info-sub {
    color: var(--color-lk-accent);
    font-size: 0.9375rem;
  }

  .lk-kelly-info-title {
    font-family: var(--font-display);
    font-size: clamp(1.5rem, 2.5vw, 2.125rem);
    line-height: 1.1;
    color: var(--color-lk-fg);
    letter-spacing: -0.015em;
    margin: 0;
  }

  .lk-kelly-info-body {
    font-family: var(--font-body);
    font-size: 0.8125rem;
    line-height: 1.55;
    color: color-mix(in oklch, var(--color-lk-fg) 78%, transparent);
    margin: 0.625rem 0 0;
  }

  /* === Drag Handle === */
  .lk-kelly-handle {
    position: absolute;
    top: 0;
    bottom: 0;
    left: calc(var(--kelly-pos) * 1%);
    transform: translateX(-50%);
    width: 56px;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: grab;
    touch-action: none;
    z-index: 3;
    transition: left 320ms var(--ease-cinema);
  }

  .lk-kelly-handle[data-dragging='true'] {
    cursor: grabbing;
    transition: none;
  }

  .lk-kelly-handle:focus-visible {
    outline: none;
  }
  .lk-kelly-handle:focus-visible .lk-kelly-handle-grip {
    outline: 2px solid var(--color-lk-accent);
    outline-offset: 6px;
  }

  .lk-kelly-handle-line {
    position: absolute;
    top: 0;
    bottom: 0;
    left: 50%;
    width: 1px;
    transform: translateX(-50%);
    background: linear-gradient(
      180deg,
      transparent 0%,
      color-mix(in oklch, var(--color-lk-accent) 60%, transparent) 15%,
      var(--color-lk-accent) 50%,
      color-mix(in oklch, var(--color-lk-accent) 60%, transparent) 85%,
      transparent 100%
    );
    pointer-events: none;
  }

  .lk-kelly-handle-grip {
    position: relative;
    width: 44px;
    height: 44px;
    border-radius: 50%;
    background: var(--color-lk-bg);
    border: 1px solid var(--color-lk-accent);
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--color-lk-accent);
    box-shadow:
      0 0 0 4px color-mix(in oklch, var(--color-lk-accent) 15%, transparent),
      0 8px 24px rgba(0, 0, 0, 0.5);
    transition:
      transform 280ms var(--ease-fluid),
      box-shadow 280ms var(--ease-fluid),
      background 280ms var(--ease-fluid);
  }

  .lk-kelly-handle:hover .lk-kelly-handle-grip,
  .lk-kelly-handle[data-dragging='true'] .lk-kelly-handle-grip {
    background: var(--color-lk-accent);
    color: var(--color-lk-bg);
    transform: scale(1.08);
    box-shadow:
      0 0 0 8px color-mix(in oklch, var(--color-lk-accent) 20%, transparent),
      0 12px 32px rgba(0, 0, 0, 0.6);
  }

  .lk-kelly-handle-grip::before {
    content: '';
    position: absolute;
    inset: -8px;
    border-radius: 50%;
    border: 1px solid var(--color-lk-accent);
    opacity: 0.6;
    animation: kelly-pulse 2.4s var(--ease-fluid) infinite;
    pointer-events: none;
  }

  @keyframes kelly-pulse {
    0%, 100% { transform: scale(1); opacity: 0.5; }
    50% { transform: scale(1.25); opacity: 0; }
  }

  .lk-kelly-handle:hover .lk-kelly-handle-grip::before,
  .lk-kelly-handle[data-dragging='true'] .lk-kelly-handle-grip::before {
    animation: none;
    opacity: 0;
  }

  /* === Quote unten zentriert im Frame === */
  .lk-kelly-quote-inset {
    position: absolute;
    bottom: clamp(3rem, 5vw, 4rem); /* über den Stop-Markers */
    left: 50%;
    transform: translateX(-50%);
    margin: 0;
    text-align: center;
    z-index: 2;
    pointer-events: none;
    max-width: min(90%, 640px);
    padding: 0 1rem;
  }

  .lk-kelly-quote-inset blockquote {
    margin: 0;
  }

  .lk-kelly-quote-text {
    font-size: clamp(1rem, 1.8vw, 1.375rem);
    color: color-mix(in oklch, var(--color-lk-fg) 90%, transparent);
    line-height: 1.3;
    margin: 0;
    text-shadow: 0 2px 12px rgba(0, 0, 0, 0.6);
  }

  .lk-kelly-quote-inset figcaption {
    margin-top: 0.5rem;
    font-size: 0.625rem;
    color: color-mix(in oklch, var(--color-lk-fg) 60%, transparent);
  }

  /* === Position Stops (Mini-Dots am Frame-Boden) === */
  .lk-kelly-stops {
    position: absolute;
    bottom: 14px;
    left: 0;
    right: 0;
    height: 36px;
    pointer-events: none;
    z-index: 3;
  }

  .lk-kelly-stop {
    position: absolute;
    bottom: 0;
    left: var(--stop-pos, 50%);
    transform: translateX(-50%);
    width: 32px;
    height: 32px;
    padding: 0;
    background: transparent;
    border: none;
    cursor: pointer;
    pointer-events: auto;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: flex-end;
    gap: 4px;
    color: color-mix(in oklch, var(--color-lk-fg) 55%, transparent);
    transition: color 280ms var(--ease-fluid);
  }

  .lk-kelly-stop::after {
    content: '';
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: currentColor;
    transition: transform 280ms var(--ease-fluid);
  }

  .lk-kelly-stop[data-active='true'] {
    color: var(--color-lk-accent);
  }

  .lk-kelly-stop[data-active='true']::after {
    transform: scale(1.6);
    box-shadow: 0 0 0 4px color-mix(in oklch, var(--color-lk-accent) 25%, transparent);
  }

  .lk-kelly-stop:hover {
    color: var(--color-lk-accent);
  }

  .lk-kelly-stop-num {
    font-family: var(--font-mono);
    font-size: 0.625rem;
    letter-spacing: 0.18em;
    opacity: 0.85;
  }

  /* === Hint Text — schwebt um den Greifer === */
  .lk-kelly-hint {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, calc(-50% + 44px));
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-family: var(--font-mono);
    font-size: 0.6875rem;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: color-mix(in oklch, var(--color-lk-fg) 70%, transparent);
    pointer-events: none;
    z-index: 2;
    transition: opacity 480ms var(--ease-fluid);
    text-shadow: 0 1px 4px rgba(0, 0, 0, 0.6);
  }

  .lk-kelly-hint[data-faded='true'] {
    opacity: 0;
  }

  .lk-kelly-hint-arrow {
    color: var(--color-lk-accent);
    font-size: 1.25rem;
    font-family: var(--font-display);
    line-height: 1;
  }
  .lk-kelly-hint-arrow--l { animation: kelly-arrow-l 1.6s var(--ease-fluid) infinite; }
  .lk-kelly-hint-arrow--r { animation: kelly-arrow-r 1.6s var(--ease-fluid) infinite; }

  @keyframes kelly-arrow-l {
    0%, 100% { transform: translateX(0); opacity: 0.4; }
    50% { transform: translateX(-4px); opacity: 1; }
  }
  @keyframes kelly-arrow-r {
    0%, 100% { transform: translateX(0); opacity: 0.4; }
    50% { transform: translateX(4px); opacity: 1; }
  }

  @media (max-width: 720px) {
    .lk-kelly-frame {
      aspect-ratio: 4 / 5; /* hochkant auf Mobile für mehr Frame-Höhe */
    }
    .lk-kelly-info {
      width: calc(100% - 2.5rem);
      top: 1rem;
      right: 1rem;
      left: 1rem;
    }
    .lk-kelly-info-card {
      text-align: left;
    }
    .lk-kelly-info-meta {
      justify-content: flex-start;
    }
    .lk-kelly-quote-inset {
      bottom: 4rem;
    }
    .lk-kelly-quote-text {
      font-size: 0.9375rem;
    }
    .lk-kelly-handle-grip {
      width: 40px;
      height: 40px;
    }
    .lk-kelly-hint {
      transform: translate(-50%, calc(-50% + 36px));
    }
  }
</style>
