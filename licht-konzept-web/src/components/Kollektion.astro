---
const base = import.meta.env.BASE_URL;

// 9 Lichtsysteme aus der eigenen Kollektion — abgebildet auf das Kollektion-Grid-Bild.
// Reihenfolge entspricht dem 3×3-Layout im Bild (von oben links, zeilenweise).
const systems = [
  { name: 'Downlight', family: 'Punktlicht', description: 'Diskrete Deckenleuchten für gleichmäßige Grundausleuchtung — die ruhigste Form von Licht.' },
  { name: 'Spotlight Narrow', family: 'Punktlicht', description: 'Eng gebündelter Strahler für gezielte Akzente. Kunst, Objekte, Architekturdetails.' },
  { name: 'Spotlight Oval Beam', family: 'Punktlicht', description: 'Ovaler Lichtkegel — ideal für Bilder, Bänke, längliche Objekte ohne harte Kanten.' },
  { name: 'Cove Light Indirect', family: 'Lineares Licht', description: 'Versteckt in Deckenkehlen — wirft Licht an die Decke zurück. Vergrößert den Raum.' },
  { name: 'Cove Light Direct', family: 'Lineares Licht', description: 'Linearer Direktstrahler von oben. Tageslicht-Wirkung über die gesamte Wand.' },
  { name: 'Cove Light + Accent', family: 'Lineares Licht', description: 'Indirekte Basis kombiniert mit gezielten Akzenten — die Königsdisziplin.' },
  { name: 'Wallwash', family: 'Wandlicht', description: 'Gleichmäßiger Lichtvorhang über die gesamte Wandfläche. Hebt Architektur, nicht Möbel.' },
  { name: 'Double Wallwash', family: 'Wandlicht', description: 'Beidseitige Wandbeleuchtung — Korridore und Durchgänge werden zur Inszenierung.' },
  { name: 'Uplight + Spot Oval', family: 'Wandlicht', description: 'Wandeinbau, der nach oben und unten strahlt. Atmosphärische Sockel-Beleuchtung.' },
];

// Gruppen-Index für Sprung-Navigation
const familyGroups = ['Punktlicht', 'Lineares Licht', 'Wandlicht'];
---

<section class="lk-section lk-kollektion" id="kollektion" aria-labelledby="kollektion-title">
  <div class="lk-container">
    <header class="lk-kollektion-header" data-reveal>
      <p class="lk-eyebrow">Eigene Kollektion</p>
      <h2 id="kollektion-title" class="lk-h1">
        Neun Lichtsysteme. <span class="lk-display-italic">Aus eigener Hand.</span>
      </h2>
      <p class="lk-body lk-kollektion-intro">
        Wir greifen nicht in den Katalog. Wir entwerfen, fertigen und installieren unsere
        eigenen Beleuchtungssysteme — abgestimmt auf das jeweilige Raumkonzept.
        Drei Familien, neun Sprachen, eine Handschrift.
      </p>
    </header>

    <div class="lk-kollektion-overview" data-reveal style="--reveal-delay: 180ms;">
      <img
        src={`${base}images/kollektion/kollektion-grid.jpg`}
        alt="Übersicht der neun Lichtsysteme: Downlight, Spotlight Narrow, Spotlight Oval Beam, Cove Light Indirect, Cove Light Direct, Cove Light plus Accent, Wallwash, Double Wallwash, Uplight plus Spot Oval"
        loading="lazy"
        decoding="async"
      />
    </div>

    <div class="lk-kollektion-families">
      {familyGroups.map((family, fi) => (
        <div class="lk-family" data-reveal style={`--reveal-delay: ${fi * 120}ms;`}>
          <p class="lk-label lk-family-label">{String(fi + 1).padStart(2, '0')} · {family}</p>
          <ul class="lk-family-list" role="list">
            {systems
              .filter((s) => s.family === family)
              .map((s) => (
                <li class="lk-family-item">
                  <h3 class="lk-h3 lk-family-name">{s.name}</h3>
                  <p class="lk-body-tight lk-family-desc">{s.description}</p>
                </li>
              ))}
          </ul>
        </div>
      ))}
    </div>

    <p class="lk-kollektion-note lk-body-tight" data-reveal>
      Alle Systeme können kombiniert, in Form, Lichttemperatur und Steuerung an Ihr Projekt
      angepasst werden. Sonderanfertigungen auf Anfrage —
      <a href="#kontakt" class="lk-link-quiet">im Lichtgespräch besprechen</a>.
    </p>
  </div>
</section>

<style>
  .lk-kollektion {
    background: var(--color-lk-bg);
    position: relative;
    overflow: hidden;
  }

  .lk-kollektion::before {
    content: '';
    position: absolute;
    top: 10%;
    right: -10%;
    width: 60vmin;
    height: 60vmin;
    background: radial-gradient(
      circle,
      color-mix(in oklch, var(--color-lk-accent) 10%, transparent) 0%,
      transparent 60%
    );
    filter: blur(80px);
    pointer-events: none;
  }

  .lk-kollektion-header {
    max-width: 720px;
    position: relative;
  }

  .lk-kollektion-intro {
    margin-top: 1.5rem;
  }

  .lk-kollektion-overview {
    margin-top: clamp(3rem, 6vw, 5rem);
    border-radius: 4px;
    overflow: hidden;
    border: 1px solid var(--color-lk-line);
    background: var(--color-lk-bg-elev);
  }

  .lk-kollektion-overview img {
    width: 100%;
    height: auto;
    display: block;
    aspect-ratio: 3 / 2;
    object-fit: cover;
  }

  .lk-kollektion-families {
    margin-top: clamp(3rem, 5vw, 4rem);
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: clamp(2rem, 4vw, 3.5rem);
  }

  .lk-family {
    display: flex;
    flex-direction: column;
  }

  .lk-family-label {
    color: var(--color-lk-accent);
    border-bottom: 1px solid var(--color-lk-line);
    padding-bottom: 0.875rem;
    margin-bottom: 1.5rem;
  }

  .lk-family-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .lk-family-item {
    border-left: 1px solid var(--color-lk-line);
    padding-left: 1.25rem;
    transition: border-color 320ms var(--ease-fluid);
  }
  .lk-family-item:hover {
    border-left-color: var(--color-lk-accent);
  }

  .lk-family-name {
    color: var(--color-lk-fg);
  }

  .lk-family-desc {
    margin-top: 0.5rem;
  }

  .lk-kollektion-note {
    margin-top: clamp(2.5rem, 4vw, 3.5rem);
    padding-top: 2rem;
    border-top: 1px solid var(--color-lk-line);
    max-width: 65ch;
    color: var(--color-lk-fg-muted);
  }

  @media (max-width: 900px) {
    .lk-kollektion-families {
      grid-template-columns: 1fr;
    }
  }
</style>
