---
import partners from '@data/partners.json';

const partnerList = partners as string[];
const hasPartners = partnerList.length > 0;
---

{hasPartners && (
  <section class="lk-section lk-partner" aria-labelledby="partner-title">
    <div class="lk-container">
      <header class="lk-partner-header" data-reveal>
        <p class="lk-eyebrow">Partner</p>
        <h2 id="partner-title" class="lk-h2">
          Wir arbeiten mit den <span class="lk-display-italic">Besten zusammen.</span>
        </h2>
      </header>

      <ul class="lk-partner-list" role="list" data-reveal style="--reveal-delay: 200ms;">
        {partnerList.map((p) => (
          <li class="lk-partner-item">{p}</li>
        ))}
      </ul>
    </div>
  </section>
)}

<style>
  .lk-partner {
    background: var(--color-lk-bg);
  }

  .lk-partner-header {
    text-align: center;
    margin-bottom: clamp(2rem, 4vw, 3rem);
  }

  .lk-partner-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-wrap: wrap;
    gap: clamp(1.5rem, 4vw, 3rem);
    justify-content: center;
    align-items: center;
    border-block: 1px solid var(--color-lk-line);
    padding-block: clamp(2rem, 4vw, 3rem);
  }

  .lk-partner-item {
    font-family: var(--font-display);
    font-style: italic;
    font-size: clamp(1.25rem, 2vw, 1.625rem);
    color: var(--color-lk-fg-muted);
    transition: color 320ms var(--ease-fluid);
  }

  .lk-partner-item:hover {
    color: var(--color-lk-accent);
  }
</style>
